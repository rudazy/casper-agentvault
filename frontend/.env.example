# Public site URL (production default: https://casperagent.xyz)
NEXT_PUBLIC_SITE_URL=https://casperagent.xyz

# Public Casper RPC endpoint (reads / small calls). CSPR.cloud is fine for queries.
NEXT_PUBLIC_CASPER_RPC_URL=https://node.testnet.casper.network/rpc
# Optional CSPR.cloud token — only needed if NEXT_PUBLIC_CASPER_RPC_URL points at cspr.cloud
NEXT_PUBLIC_CSPR_CLOUD_AUTH_TOKEN=

# Server-only: RPC used for put_transaction of large session WASM (Vault deposit proxy ~370KB).
# CSPR.cloud returns HTTP 413 for these. Default/recommended:
# CASPER_PUT_RPC_URL=https://node.testnet.casper.network/rpc

# Casper chain name for contract calls (testnet default)
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test

# Package hashes (optional — defaults in lib/casper/contract-config.ts and
# contracts/agentvault-core/resources/casper-test-contracts.toml)
NEXT_PUBLIC_ESCROW_PACKAGE_HASH=
NEXT_PUBLIC_ATTESTATION_PACKAGE_HASH=
NEXT_PUBLIC_VAULT_PACKAGE_HASH=

# csprclick-template works on localhost only. Before Vercel deploy:
# 1) Register at https://console.cspr.build with casperagent.xyz (and preview domains)
# 2) Set the app id here locally and in Vercel env vars, then redeploy
NEXT_PUBLIC_CSPR_CLICK_APP_ID=csprclick-template

# Optional: enables LLM reasoning in agents API (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Server-only: PEM of the key that installed the Vault package (payable deposit path).
# CSPR.click cannot sign large session+WASM txs (HTTP 413), so owner deposits are
# signed here. Must match the connected wallet public key.
# Vercel: paste full PEM (BEGIN…END). Real newlines OR a single line with \n between
# lines. No surrounding quotes. Wrong/mangled PEM surfaces as DER "decode tag of seq".
# CASPER_VAULT_OPERATOR_PEM=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----