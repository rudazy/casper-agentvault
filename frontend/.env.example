# Public site URL (production default: https://casperagent.xyz)
NEXT_PUBLIC_SITE_URL=https://casperagent.xyz

# Public Casper RPC endpoint (testnet default)
NEXT_PUBLIC_CASPER_RPC_URL=https://node.testnet.cspr.cloud/rpc
NEXT_PUBLIC_CSPR_CLOUD_AUTH_TOKEN=your-cspr-cloud-access-token

# Casper chain name for contract calls (testnet default)
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test

# Package hashes (optional — defaults in lib/casper/contract-config.ts and
# contracts/agentvault-core/resources/casper-test-contracts.toml)
NEXT_PUBLIC_ESCROW_PACKAGE_HASH=
NEXT_PUBLIC_ATTESTATION_PACKAGE_HASH=

# csprclick-template works on localhost only. Before Vercel deploy:
# 1) Register at https://console.cspr.build with casperagent.xyz (and preview domains)
# 2) Set the app id here locally and in Vercel env vars, then redeploy
NEXT_PUBLIC_CSPR_CLICK_APP_ID=csprclick-template

# Optional: enables LLM reasoning in agents API (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini