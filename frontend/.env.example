# Public Casper RPC endpoint (testnet default)
NEXT_PUBLIC_CASPER_RPC_URL=https://node.testnet.casper.network/rpc

# Casper chain name for contract calls (testnet default)
NEXT_PUBLIC_CASPER_CHAIN_NAME=casper-test

# Set after deploying Odra contracts (with or without hash- prefix)
NEXT_PUBLIC_ESCROW_PACKAGE_HASH=
NEXT_PUBLIC_ATTESTATION_PACKAGE_HASH=

# Register your own app id at CSPR.click before production deploy
NEXT_PUBLIC_CSPR_CLICK_APP_ID=csprclick-template

# Optional: enables LLM reasoning in agents API (server-side only)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini