# Odra Casper Livenet (testnet) — copy to .env and fill in locally only.
# Export secret_key.pem from Casper Wallet: Menu > Download account keys.
# CSPR.cloud token: https://cspr.cloud

ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./secret_key.pem
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud
ODRA_CASPER_LIVENET_EVENTS_URL=https://node-sse.testnet.cspr.cloud/events/main
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
CSPR_CLOUD_AUTH_TOKEN=your-cspr-cloud-access-token